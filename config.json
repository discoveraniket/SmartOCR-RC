{
    "OCR_SETTINGS": {
        "lang": "en",
        "use_angle_cls": true,
        "show_log": false,
        "ocr_version": "PP-OCRv4",
        "use_gpu": false,
        "det_db_thresh": 0.3,
        "det_db_box_thresh": 0.3,
        "det_db_unclip_ratio": 2.0,
        "det_limit_side_len": 1500,
        "drop_score": 0.05,
        "enable_mkldnn": true,
        "cpu_threads": 4,
        "rec_image_shape": "3, 48, 320",
        "crop_padding": 100,
        "auto_crop": true,
        "dump_text_flow": true,
        "default_input_dir": "D:/Codes/GitHub/RC-PaddleOCR - v2/data",
        "default_output_dir": "D:/Codes/GitHub/RC-PaddleOCR - v2/output"
    },
    "LLM_SETTINGS": {
        "step1_model": "qwen2.5:14b-instruct",
        "text_to_JSON_model": "llama3.2:3b",
        "models_path": "D:\\LLMs\\models",
        "max_loaded_models": "3",
        "keep_alive": "5m",
        "standard_prompt": "USE_DEFAULT",
        "text_to_json_prompt": "USE_DEFAULT"
    },
    "KEY_MAP": {
        "viewer_next": "<Control-Right>",
        "viewer_prev": "<Control-Left>",
        "viewer_save_data": "<Control-S>",
        "viewer_save_img": "<Control-I>",
        "viewer_rotate": "<Control-R>",
        "viewer_crop": "<Control-C>",
        "viewer_reprocess": "<Control-A>",
        "viewer_settings": "<Control-G>",
        "viewer_reset": "<Control-0>"
    }
